//reading duration and collection time info and sending water level detection
#include <SoftwareSerial.h>

const byte rxPin = 2;
const byte txPin = 3;

SoftwareSerial sensor_board(rxPin, txPin);

bool received_duration = false;
bool sent_water_signal = false;

int water_detection = 0; 
int current_water_level = 3;

int duration;
int collection_interval;

void setup() {
  Serial.begin(9600);
  sensor_board.begin(9600);
  delay(5000);
}

void loop() {

  if (!received_duration) {
    byte buffer1[sizeof(int) * 2];
    if (sensor_board.available() >= sizeof(buffer1)) {
      sensor_board.readBytes(buffer1, sizeof(buffer1));
      memcpy(&duration, buffer1, sizeof(int));
      memcpy(&collection_interval, buffer1 + sizeof(int), sizeof(int));
      received_duration = true;
      Serial.print("Duration: ");
      Serial.println(duration);
      Serial.print("Interval: ");
      Serial.println(collection_interval);
    }
  }
  if (!sent_water_signal && current_water_level > 2) {
    water_detection = 1;
    sensor_board.write((byte*)&water_detection, sizeof(water_detection));
    sent_water_signal = true;
    Serial.println("Water signal sent");
  }
}

