//potentiometer dial code for tank collection interval and simulation duration
//sending duration and collection time info and receiving water level detection 
#include <SoftwareSerial.h>
const byte rxPin = 2;
const byte txPin = 3;
int tank_interval = 10;
int sim_duration = 360;
int sim_pin = A2;
int col_time_pin = A3;
int sim_dial_pot = 0;
int col_time_pot = 0;
int water_presence;
bool sent_duration = false;
bool water_detect = false;
int motor_to_sensor = 0;
SoftwareSerial motor_board(rxPin, txPin);
void setup() {
  // put your setup code here, to run once:
  Serial.begin(9600);
  motor_board.begin(9600);
  delay(5000);
  //sim_dial_pot = analogRead(sim_pin);
  //col_time_pot = analogRead(col_time_pin);
  //sim_duration = map(sim_dial_pot, 0, 1023, 0, 900);//0-15 min in seconds
  //tank_interval = map(col_time_pot, 0, 1023, 0, 45);//tank interval time in seconds
 
}

void loop() {
  // put your main code here, to run repeatedly:
  if (!sent_duration){
    motor_board.write((byte*)&sim_duration, sizeof(sim_duration));
    motor_board.write((byte*)&tank_interval, sizeof(tank_interval));
    Serial.println("sending");
    sent_duration = true;
  }
 
  if (!water_detect){
    byte buffer[sizeof(int)];
    if (motor_board.available() >= sizeof(buffer)){
      motor_board.readBytes(buffer, sizeof(buffer));
      memcpy(&water_presence, buffer, sizeof(int));
      water_detect = true;
      Serial.print("Water Presence: ");
      Serial.print(water_presence);
    }
  }
}
