  tank_interval = map(col_time_pot, 0, 1023, 0, 45);//tank interval time in seconds
  Serial.print(sim_dial_pot);
  Serial.print(" ");
  Serial.print(sim_duration);
  Serial.print(" ");
  Serial.print(col_time_pot);
  Serial.print(" ");
  Serial.print(tank_interval);
  Serial.println(" ");

  motor_board.write((byte*)&sim_duration, sizeof(sim_duration));
  motor_board.write((byte*)&tank_interval, sizeof(tank_interval));  
}

void loop() {
