//Dr. Hofstetter recommended trying smaller delay for smoother vibration
//DON'T PLUG IN ENA PINS 
#define STEP_PIN 9
#define DIR_PIN 8

void setup() {
  pinMode(STEP_PIN, OUTPUT);
  pinMode(DIR_PIN, OUTPUT);
  pinMode(13, OUTPUT);

  digitalWrite(DIR_PIN, HIGH);
}

void loop() {
  // step pulse
  for (int x = 0; x<200; x++){
    digitalWrite(STEP_PIN, HIGH);
    digitalWrite(13, HIGH);   // LED ON
    delay(1);

    digitalWrite(STEP_PIN, LOW);
    digitalWrite(13, LOW);    // LED OFF
    delay(1);
  }
  
}

