        hydrograph_time_2 = hydrograph_time_3;
        hydrograph_time_3 = current_time_stamp;
        hydrograph_level_1 = hydrograph_level_2;
        hydrograph_level_2 = hydrograph_level_3;
        hydrograph_level_3 = current_water_level;
        intensity = (hydrograph_level_3 - hydrograph_level_1)*2.2*18.8/(hydrograph_time_3 - hydrograph_time_1);
        hydrograph_time_step = (hydrograph_level_1 + hydrograph_level_3)/2;
        if (intensity < 0){
          intensity = 0;
        }
        filtered_intensity = getMovingAverage(intensity);
        filtered_time_step_1 = filtered_time_step_2;
        filtered_time_step_2 = filtered_time_step_3;
        filtered_time_step_3 = hydrograph_time_step; 
        x = map(filtered_time_step_1, 0, sim_duration_secs*3, 32, 308);
        y = map(filtered_intensity, 0, 90, 163, 5);
        tft.drawPixel(x, y, ILI9341_WHITE);
        tft.drawLine(last_x, last_y, x, y, ILI9341_WHITE);
        tft.fillRect(240, 203, 60, 12, ILI9341_BLACK);
        tft.setCursor(240, 203);
        tft.println(filtered_intensity);
        last_x = x;
        last_y = y; 
        if (dataFile){
