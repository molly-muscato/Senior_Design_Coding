  } else {
    if (current_time - previous_time >= sensor_time_interval){
      long duration = sonar.ping_median(5);
      float distance = duration*speed_of_sound/2.0;
      current_water_level = sensor_height - distance;
      if (current_water_level >= 0 && current_water_level <= 13.5){
        current_time_stamp = current_time/1000;
        Serial.print("Time: ");
        Serial.print(current_time_stamp);
