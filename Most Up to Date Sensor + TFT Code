void bubbleSort(float array[], int length){
  float temp;
  bool swapped;
  for (int i = 0; i < length; i = i + 1){
    swapped = false;
    for (int j = 0; j < length - 1 - i; j = j + 1){
      if (array[j] > array[j + 1]){
        temp = array[j];
        array[j] = array[j+1];
        array[j+1] = temp;
        swapped = true;
      }
    }
    if (!swapped){
      break;
    }
  }
}
