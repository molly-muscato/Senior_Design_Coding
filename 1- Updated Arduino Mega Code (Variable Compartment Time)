void getFileName(DateTime now, char* name){
  sprintf(name, "%02d%02d%02d%02d.csv", now.month(), now.day(), now.hour(), now.minute());
}

//set up for (0,0) of hydrograph plot 
float x = 32;
float y = 145;
float last_x = 32;
float last_y = 145;

//set up for moving average filter 
const int filter_size = 5;
float filter_array[filter_size] = {0};
int index = 0;
float moving_average_sum = 0;
float filtered_intensity = 0; 

float getMovingAverage(float new_intensity){
  moving_average_sum = moving_average_sum - filter_array[index];
  filter_array[index] = new_intensity;
  moving_average_sum = moving_average_sum + new_intensity;
  index = (index + 1) % filter_size;
  float moving_average = moving_average_sum / filter_size; 
  return moving_average;
}

//assigning all global variables 
//general ultrasonic sensor loop 
float sensor_height = 0; 
float sum_sensor_height = 0; 
float temperature_C = 24;
float speed_of_sound = 20.05*sqrt(273.15 + temperature_C)/10000;
float current_water_level = 0; 
unsigned long previous_time = 0; //previous time stamp in milliseconds
unsigned long current_time = 0;
float previous_time_stamp = 0;
float current_time_stamp = 0;
const long sensor_time_interval = 1000; //water level measurement time interval in milliseconds
int sim_duration_secs = 60;
long  sim_duration_millis = sim_duration_secs*1000L;
//hydrograph loop
float hydrograph_time_1 = 0;
float hydrograph_time_2 = 0;
float hydrograph_time_3 = 0;
float filtered_time_step_1 = 0;
float filtered_time_step_2 = 0;
float filtered_time_step_3 = 0; 
float hydrograph_level_1 = 0;
float hydrograph_level_2 = 0;
float hydrograph_level_3 = 0; 
float hydrograph_time_step = 0;
float hydrograph_time_step_length = 0; 
float filtered_time_step_length_1 = 0;
float filtered_time_step_length_2 = 0;
float filtered_time_step_length_3 = 0;  
float intensity = 0;
float runoff_volume_calc_2 = 0; 
//runoff volume and tank loop 
long last_compartment_time = 0;
int collection_time_secs = 10; 
long collection_time_millis = collection_time_secs*1000L; 
float total_water_height = 0; 
float total_runoff = 0;
float total_precipitation = 0;
float total_infiltration = 0;
float previous_water_level = 0;
int rain_intensity = 4; 
//ending code 
int counter = 0; 

NewPing sonar(TRIG_PIN, ECHO_PIN, MAX_DISTANCE);

//led lights 
#define motor_inactive 44
#define motor_active 42
#define tank_empty 46

//dials 
int sim_pin = A2;
int col_time_pin = A3; 
int rain_pin = A1; 
int sim_dial_pot = 0;
int col_time_pot = 0;
int rain_pot = 0;

void setup(){
  Serial.begin(115200);
  delay(5000);
  Serial.println("Start...");
  pinMode(53, OUTPUT);
  pinMode(53, HIGH);
  pinMode(SD_CS, OUTPUT);
  pinMode(TFT_CS, OUTPUT);

  pinMode(tank_empty, OUTPUT);
  pinMode(motor_active, OUTPUT);
  pinMode(motor_inactive, OUTPUT);
  sim_dial_pot = analogRead(sim_pin); // --> might need to move into void loop with counter if we want user to be able to adjust dial once simulation has started
  col_time_pot = analogRead(col_time_pin);
  rain_pot = analogRead(rain_pin);
  sim_duration_secs = map(sim_dial_pot, 0, 1023, 0, 900);//0-15 min in seconds
  sim_duration_millis = sim_duration_secs*1000L;
  collection_time_secs = map(col_time_pot, 0, 1023, 0, 45);//tank interval time in seconds
  rain_intensity = map(rain_pot, 0, 1023, 0, 5);
  if (collection_time_secs< 7.5){
    collection_time_secs = 5;
  } else if (collection_time_secs < 12.5){
    collection_time_secs = 10; 
  } else if (collection_time_secs < 17.5){
    collection_time_secs = 15; 
  } else if (collection_time_secs < 22.5){
    collection_time_secs = 20; 
  } else if (collection_time_secs < 27.5){
    collection_time_secs = 25; 
  } else if (collection_time_secs < 32.5){
    collection_time_secs = 30; 
  } else if (collection_time_secs < 37.5){
    collection_time_secs = 35;
  } else if (collection_time_secs < 42.5){
    collection_time_secs = 40; 
  } else if (collection_time_secs < 47.5){
    collection_time_secs = 45;  
  }
  collection_time_millis = collection_time_secs*1000L; 
  Serial.print(sim_dial_pot);
  Serial.print(" ");
  Serial.print(sim_duration_secs);
  Serial.print(" ");
  Serial.print(col_time_pot);
  Serial.print(" ");
  Serial.print(collection_time_secs);
  Serial.println(" ");
  Serial.print(rain_pot);
  Serial.print(" ");
  Serial.println(rain_intensity);

  Wire.begin();
  delay(500);
  pinMode(SD_CS, OUTPUT);
  digitalWrite(SD_CS, HIGH);
  if(!rtc.begin()){
    Serial.println("Couldn't find RTC");
  } else{
    Serial.println("RTC found");
  }
  DateTime now = rtc.now();
  if (!now.isValid()) {
    Serial.println("RTC time invalid!");
  } else {
  }
  getFileName(now, file_name);
  Serial.println(file_name);

  digitalWrite(SD_CS, LOW);
  digitalWrite(TFT_CS, HIGH);
  if (!SD.begin(SD_CS)){
    Serial.print("SD init failed");
  } else{
    dataFile = SD.open(file_name, FILE_WRITE);
    if (dataFile){
      dataFile.println("water level time step(s), water level (cm), hydrograph time step (s), runoff flow rate (cm3/s)");
      dataFile.flush();
    } else {
      Serial.println("Couldn't open SD file");
      dataFile = SD.open(file_name, FILE_WRITE);
      if (dataFile){
        dataFile.println("water level time step(s), water level (cm), hydrograph time step (s), runoff flow rate (cm3/s)");
        dataFile.flush(); 
      }
    }
  }
  
  digitalWrite(SD_CS, HIGH);
  digitalWrite(TFT_CS, LOW);
  tft.begin();
  tft.setRotation(1);
  tft.fillScreen(ILI9341_BLACK);
  tft.setTextColor(ILI9341_WHITE);
  tft.setTextSize(2);
  tft.setCursor(75,10);
  tft.println("Runoff Hydrograph");
  tft.setTextSize(1);
  tft.setCursor(5, 191);
  tft.println("Cumulative Runoff Volume (cm^3): ");
  tft.SetCursor(5, 203);
  tft.println("Runoff Flow Rate (cm^3/s): ");
  tft.setCursor(5, 215);
  tft.println("Time Elapsed (seconds): ");
  tft.setCursor(5, 227);
  tft.println("Collection Time Interval (seconds): ");
  tft.setCursor(240, 227);
  tft.println(collection_time_secs);
  tft.setCursor(150,155);
  tft.println("Time (s)");
  tft.setCursor(17, 150);
  tft.println("0");
  tft.setCursor(292, 150);//used to be 300
  tft.println(sim_duration_secs*3);
  tft.setCursor(17, 5);
  tft.println("90");
  tft.setRotation(0);
  tft.setCursor(75, 5);
  tft.println("Runoff Flow Rate (cm^3/s)");
  tft.setRotation(1);
  tft.drawFastHLine(32, 145, 276, ILI9341_WHITE);
  tft.drawFastVLine(32, 5, 140, ILI9341_WHITE);

  for (int i = 0; i < 5; i = i + 1){
    long initial_ToF = sonar.ping_median(5);
    float initial_height = initial_ToF*speed_of_sound/2.0;
    sum_sensor_height = sum_sensor_height + initial_height; 
    Serial.print(millis()/1000);
    Serial.print(", ");
    delay(855);
  }
  sensor_height = sum_sensor_height/5;
  Serial.print(sensor_height);
  Serial.print(" "); 

  pinMode(STEP_PIN, OUTPUT);
  pinMode(DIR_PIN, OUTPUT);
  digitalWrite(DIR_PIN, LOW);
}

void loop(){
  current_time = millis();
  if (current_time >= sim_duration_millis*3){
    Serial.print("End of simulation.");
    dataFile.close();
    total_precipitation = rain_intensity*1000*sim_duration_secs/60; //in cm3
    total_infiltration = total_precipitation - total_runoff; 
    tft.fillRect(5, 203, 300, 12);
    tft.fillRect(5, 215, 300, 12);
    tft.setCursor(5, 203);
    tft.println("Cumulative Precipitation (cm^3): ");
    tft.setCursor(5, 215);
    tft.println("Cumulative Infiltration (cm^3): ");
    tft.fillRect(240, 203, 80, 12, ILI9341_BLACK);
    tft.setCursor(240, 203);
    tft.println(total_precipitation);
    tft.fillRect(240, 215, 80, 12, ILI9341_BLACK);
    tft.setCursor(240, 215);
    tft.println(total_infiltration);
    while(1);
  } else {
    if (current_time - previous_time >= sensor_time_interval){
      long duration = sonar.ping_median(5);
      float distance = duration*speed_of_sound/2.0;
      current_water_level = sensor_height - distance;
      if (current_water_level < -1){
        current_time_stamp = current_time/1000; 
        last_compartment_time = current_time; 
        hydrograph_level_1 = 0;
        hydrograph_level_2 = 0; 
        hydrograph_level_3 = 0; 
        hydrograph_time_1 = current_time_stamp;
        hydrograph_time_2 = current_time_stamp;
        hydrograph_time_3 = current_time_stamp; 
      } else { 
        current_time_stamp = current_time/1000;
        Serial.print("Time: ");
        Serial.print(current_time_stamp);
        Serial.print("s | Median Water Levels: ");
        Serial.print(current_water_level);
        Serial.print(" cm | ");
        tft.fillRect(240, 215, 60, 12, ILI9341_BLACK);
        tft.setCursor(240, 215);
        tft.println(current_time_stamp);
        hydrograph_time_1 = hydrograph_time_2;
        hydrograph_time_2 = hydrograph_time_3;
        hydrograph_time_3 = current_time_stamp;
        hydrograph_level_1 = hydrograph_level_2;
        hydrograph_level_2 = hydrograph_level_3;
        hydrograph_level_3 = current_water_level;
        intensity = (hydrograph_level_3 - hydrograph_level_1)*2*19/(hydrograph_time_3 - hydrograph_time_1);
        hydrograph_time_step = (hydrograph_time_1 + hydrograph_time_3)/2;
        hydrograph_time_step_length = hydrograph_time_3 - hydrograph_time_1; 
        if (intensity < 0){
          intensity = 0;
        }
        filtered_intensity = getMovingAverage(intensity);
        filtered_time_step_1 = filtered_time_step_2;
        filtered_time_step_2 = filtered_time_step_3;
        filtered_time_step_3 = hydrograph_time_step; 
        filtered_time_step_length_1 = filtered_time_step_length_2; 
        filtered_time_step_length_2 = filtered_time_step_length_3;
        filtered_time_step_length_3 = hydrograph_time_step_length; 
        x = map(filtered_time_step_1, 0, sim_duration_secs*3, 32, 308);
        y = map(filtered_intensity, 0, 90, 145, 5);
        tft.drawPixel(x, y, ILI9341_WHITE);
        tft.drawLine(last_x, last_y, x, y, ILI9341_WHITE);
        tft.fillRect(240, 203, 60, 12, ILI9341_BLACK);
        tft.setCursor(240, 203);
        tft.println(filtered_intensity);
        Serial.print("Hydrograph Time Step: ");
        Serial.print(filtered_time_step_1);
        Serial.print("s | ");
        Serial.print("Filtered Intensity: ");
        Serial.print(filtered_intensity);
        Serial.print("cm3/s | ");
        Serial.print("Hydrograph Time Step Length: ");
        Serial.print(filtered_time_step_length_1);
        Serial.println(" s ");
        last_x = x;
        last_y = y; 
        runoff_volume_calc_2 = runoff_volume_calc_2 + filtered_intensity*filtered_time_step_length_1; 
        if (dataFile){
          dataFile.print(current_time_stamp);
          dataFile.print(",");
          dataFile.print(current_water_level);
          dataFile.print(",");
          dataFile.print(filtered_time_step_1);
          dataFile.print(",");
          dataFile.println(filtered_intensity);
          dataFile.flush();
        } else {
          dataFile = SD.open(file_name, FILE_WRITE);
          if (dataFile){
            dataFile.print(current_time_stamp);
            dataFile.print(",");
            dataFile.print(current_water_level);
            dataFile.print(",");
            dataFile.print(filtered_time_step_1);
            dataFile.print(",");
            dataFile.println(filtered_intensity);
            dataFile.flush();
            Serial.println("Data Logged");
          }
        }
        previous_water_level = current_water_level; 
      }
      col_time_pot = analogRead(col_time_pin);
      collection_time_secs = map(col_time_pot, 0, 1023, 0, 45);//tank interval time in seconds
      if (collection_time_secs< 7.5){
        collection_time_secs = 5;
      } else if (collection_time_secs < 12.5){
        collection_time_secs = 10; 
      } else if (collection_time_secs < 17.5){
        collection_time_secs = 15; 
      } else if (collection_time_secs < 22.5){
        collection_time_secs = 20; 
      } else if (collection_time_secs < 27.5){
        collection_time_secs = 25; 
      } else if (collection_time_secs < 32.5){
        collection_time_secs = 30; 
      } else if (collection_time_secs < 37.5){
        collection_time_secs = 35;
      } else if (collection_time_secs < 42.5){
        collection_time_secs = 40; 
      } else if (collection_time_secs < 47.5){
        collection_time_secs = 45;  
      }
      collection_time_millis = collection_time_secs*1000L; 
      if (current_time - last_compartment_time >= collection_time_millis){
        if (current_water_level > 0){
          total_water_height = current_water_level + total_water_height;
          total_runoff = total_water_height*2*19; //in cm3
          last_compartment_time = current_time; 
          tft.fillRect(240, 191, 80, 12, ILI9341_BLACK);
          tft.setCursor(240, 191);
          tft.println(total_runoff);
        }
        if (current_water_level > 1 && !sent_water_signal){
          sent_water_signal = true;
        if (sent_water_signal == true && current_water_level > 0){
          for (int i = 0; i < StepsPerRev; i = i + 1){
            digitalWrite(STEP_PIN, HIGH);
            delayMicroseconds(500);
            digitalWrite(STEP_PIN, LOW);
            delayMicroseconds(500);
          }
          hydrograph_level_2 = hydrograph_level_2 - hydrograph_level_3; 
          hydrograph_level_3 = 0;
          digitalWrite(motor_active, HIGH);
          digitalWrite(motor_inactive, LOW);
          count = count + 1;
          if (count == 16){
            digitalWrite(tank_empty, HIGH);
          }
          if (count == 17){
            count = 0; 
            digitalWrite(tank_empty, LOW);
          }
        } else {
          digitalWrite(motor_inactive, HIGH);
          digitalWrite(motor_active, LOW);
        }
      }
      previous_time_stamp = current_time_stamp;
      previous_time = current_time; 
    }
  }
}
