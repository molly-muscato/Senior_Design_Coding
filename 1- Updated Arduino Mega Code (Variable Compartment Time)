//stepper motor variables 
#define STEP_PIN 12
#define DIR_PIN 13
const int StepsPerRev = 200;
bool sent_water_signal = false; 
int tank_empty_count = 0; 

Adafruit_ILI9341 tft = Adafruit_ILI9341(TFT_CS, TFT_DC);
File dataFile;
char file_name[13];
