//set up for moving average filter 
const int filter_size = 5; // moving average filter window size of 5 elected based on data analysis 
float filter_array[filter_size] = {0}; //establishing empty array to store values in moving average filter window
int index = 0; // index used in circular buffer to replace oldest runoff flow rate with newest
float moving_average_sum = 0.0; // variable used to store sum of values in moving average fitler window
float filtered_runoff_rate = 0.0; // final processed runoff flow rate reported in csv file and digital hydrograph

//function used to calculate moving average via a circular buffer (oldest runoff flow rate in window is subtracted from the moving average sum while the newest is added and then the oldest value is replaced by the newest in the array via a moving index)
float getMovingAverage(float new_runoff_rate){
  moving_average_sum = moving_average_sum - filter_array[index];
  filter_array[index] = new_runoff_rate;
  moving_average_sum = moving_average_sum + new_runoff_rate;
  index = (index + 1) % filter_size; //modulo function used to functionally reset index to 0 once the index has surpassed the size of the moving average filter window
  float moving_average = moving_average_sum / filter_size; // the sum of the runoff flow rates in the window is divided by the size of the window to derive an average
  return moving_average; // filtered runoff flow rate returned to user 
}

