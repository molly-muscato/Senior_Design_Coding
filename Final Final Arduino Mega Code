void loop(){
  current_time = millis() - 15000; // millis used to keep track of timestamps and ensure that sensor is taking readings and compartments are moving at fixed intervals --> much more reliable than just using delay
  if (current_time >= sim_duration_millis*3){ // once the elapsed time exceeds three times the length of the rainfall duration inputted by the user, the ending loop is triggered which terminates sensor readings and motor motion and calculates final values
    Serial.print("End of simulation."); // end signal printed to serial monitor for validation purposes 
    dataFile.close();
    total_precipitation = rain_intensity*1000.0*sim_duration_secs/60.0; // total precipitation calculated by multiplying the rainfall intensity in L/min by the rainfall duration in seconds and then adjusting for units
    total_infiltration = total_precipitation - total_runoff; // total infiltration calculated by subtracting cumulative runoff volume (method 1) from total precipitation volume 
    tft.fillRect(5, 203, 300, 12, ILI9341_BLACK);
    tft.fillRect(5, 215, 300, 12, ILI9341_BLACK);
    tft.setCursor(5, 203);
    tft.println("Cumulative Precipitation (cm^3): "); // cumulative precipitation volume provided to user on TFT display 
    tft.setCursor(5, 215);
    tft.println("Cumulative Infiltration (cm^3): "); // cumulative infiltration volume provided to user on TFT display 
    tft.fillRect(240, 203, 80, 12, ILI9341_BLACK);
    tft.setCursor(240, 203);
    tft.println(total_precipitation);
    tft.fillRect(240, 215, 80, 12, ILI9341_BLACK);
    tft.setCursor(240, 215);
    tft.println(total_infiltration);
    if (dataFile){ // opening SD card csv file 
          dataFile.print("Total Runoff Volume (cm3)"); // at the end of the simulation, the total runoff, precipitation, and infiltration volume is recorded in the csv file 
          dataFile.print(",");
          dataFile.print(total_runoff);
          dataFile.print(",");
          dataFile.print("Total Precipitation Volume (cm3)");
          dataFile.print(",");
          dataFile.print(total_precipitation);
          dataFile.print(",");
          dataFile.print("Total Infiltration Volume (cm3)");
          dataFile.print(",");
          dataFile.print(total_infiltration);
          dataFile.flush();
        } else { // if the SD card fails to open, the program attempts to open it one more time 
          dataFile = SD.open(file_name, FILE_WRITE);
          if (dataFile){
            dataFile.print("Total Runoff Volume (cm3)"); 
            dataFile.print(",");
            dataFile.print(total_runoff);
            dataFile.print(",");
            dataFile.print("Total Precipitation Volume (cm3)");
            dataFile.print(",");
            dataFile.print(total_precipitation);
            dataFile.print(",");
            dataFile.print("Total Infiltration Volume (cm3)");
            dataFile.print(",");
            dataFile.print(total_infiltration);
            dataFile.flush();
            Serial.println("Data Logged");
          }
        }
    while(1); // while statement used to stop program from continuously running void loop after simulation has ended 
  } else { // if elapsed time does not exceed the ending threshold, main loop is entered 
    if (current_time - previous_time >= sensor_time_interval && current_time >= 0 && (current_time%1000) == 0){ // conditional statement used to ensure that reading is only taken once 1 second has elapsed between previous time stamp and current time stamp, current_time >= 15000 used to essentially provide a buffer that forces sensor readings to begin on even time step rather than immediately after all of the initialization in the set-up loop has been completed 
      long duration = sonar.ping_median(5); // median filtering used once again to find median of 5 sensor readings take 29 ms apart 
      float distance = duration*speed_of_sound/2.0; // sensor duration reading converted to distance between sensor and water surface 
      current_water_level = sensor_height - distance; // distance between water surface and sensor subtracted from calibrated sensor height to determine water level in cm
      if (!rainfall_start) { //after 15 seconds, the sensor has been properly calibrated, all components have been initialized, and the user should power the pump on; rainfall_start boolean variable ensures this loop is only run once for sake of processing time 
        tft.setTextColor(ILI9341_GREEN);
        tft.setCursor(150, 175);
        tft.println("START PUMP"); // message on TFT display tells user to start the pump 
        tft.setTextColor(ILI9341_WHITE);
        rainfall_start = true; // rainfall_start set to true so loop won't run again 
        tft.drawFastVLine(hyetograph_location_x1, 5, hyetograph_location_y - 5, ILI9341_WHITE); // vertical line drawn to mark start of hyetograph 
      }
      if (current_time < sim_duration_millis){ // hyetograph should only be plotted if the current time is less than the user specified rainfall duration
        float hyetograph_location_x = 32.0 + (290.0-32.0)*(current_time/1000)/(sim_duration_secs*3); // interpolation used to scale current time stamp to hyetograph x axis 
        tft.drawFastHLine(hyetograph_location_x1, hyetograph_location_y, hyetograph_location_x - hyetograph_location_x1, ILI9341_WHITE); // horizontal line drawn to create real time hyetograph
      } else if (current_time >= sim_duration_millis && !rainfall_end){ // conditional statements used to ensure hyetograph finishes plotting once current time exceeds rainfall duration and that stop message is only sent once
        tft.drawFastVLine(hyetograph_location_x2, 5, hyetograph_location_y - 5, ILI9341_WHITE); // vertical line drawn mark end of hyetograph
        tft.drawFastHLine(hyetograph_location_x1, hyetograph_location_y, hyetograph_location_x2 - hyetograph_location_x1, ILI9341_WHITE); // horizontal line drawn to create real time hyetograph
        tft.setTextColor(ILI9341_RED);
        tft.fillRect(150, 175, 100, 12, ILI9341_BLACK);
        tft.setCursor(150, 175);
        tft.println("STOP PUMP"); // message on TFT display tells user to stop pump 
        tft.setTextColor(ILI9341_WHITE);
        rainfall_end = true; // rainfall_end set to true so loop won't run again 
      }
      if (current_water_level < -1){ // if the current water level is negative, this signifies that the distance between the sensor and surface is greater than the distance between the sensor and bottom of the collection tank which could only occur if the tank has been removed 
        current_time_stamp = current_time/1000.0; // time stamp in milliseconds converted to seconds for printing to TFT display
        last_compartment_time = current_time; // if the tank has been removed, the last compartment time is continuously set to the current time, so that the collection time that should pass before the compartments moves again is measured from the time stamp that the tank is placed back on the track rather than the last recorded time stamp at which the compartment moved
        hydrograph_level_1 = 0.0; // if the tank has been removed, the stored water level variables are all set to 0 so that once a new water level reading is taken, the runoff flow rate is measured from the correct 0 reference point rather than the previously stored water level readings in the last compartment before the tank was removed
        hydrograph_level_2 = 0.0; 
        hydrograph_level_3 = 0.0; 
        hydrograph_level_4 = 0.0;
        hydrograph_time_1 = current_time_stamp; // similarly, if the tank has been removed, the stored time stamp variable are all set to the current time stamp so that once a new water level reading is taken, the runoff flow rate is calculated based on the elapsed time between when the tank was placed on the track and when the new water level was recorded rather than the previously stored time stamps from before the tank was removed
        hydrograph_time_2 = current_time_stamp;
        hydrograph_time_3 = current_time_stamp; 
        hydrograph_time_4 = current_time_stamp; 
        digitalWrite(motor_active, LOW); // if the tank has been removed, the motor should not activate, and thus the motor active LED is turned off while the motor inactive LED is turned on 
        digitalWrite(motor_inactive, HIGH);
      } else { // if the current water level is positive, then the tank should be on the track, and thus, water levels should be recorded and the system should operate at full function
        if (current_water_level < 0){ // due to sensor jitter, at very low water levels, occasionally, the sensor will read a slightly negative water level (ex. -0.1 cm), and thus, this conditional statement adjusts these negative values to 0
          current_water_level = 0; 
        }
        current_time_stamp = current_time/1000.0;
        // time and water level reading data printed to serial monitor for troubleshooting 
        Serial.print("Time: ");
        Serial.print(current_time_stamp);
        Serial.print("s | Median Water Levels: ");
        Serial.print(current_water_level);
        Serial.print(" cm | ");
        tft.fillRect(240, 215, 60, 12, ILI9341_BLACK);
        tft.setCursor(240, 215);
        tft.println(current_time_stamp); // elapsed time printed to TFT display 
        //variables used to store previous time stamp information so that runoff flow rate can be calculated across a 3 second interval. 
        //This interval was selected based on extensive data analysis as determining the runoff flow rate over 1 or 2 second intervals (i.e. between 3-4 seconds or 3-5 seconds) was found to be less reliable and more susceptible to flucutations caused by sensor jitter rather than meaningful changes in water level height. Calculating flow rate over a 3 second window significantly enhanced hydrograph shape as random fluctuations in water level are minimized across larger time intervals. 
        hydrograph_time_1 = hydrograph_time_2;
        hydrograph_time_2 = hydrograph_time_3;
        hydrograph_time_3 = hydrograph_time_4;
        hydrograph_time_4 = current_time_stamp; 
        //variables used to store previous water level information so that runoff flow rate can be calculated across a 3 second interval. 
        //This interval was selected based on extensive data analysis as determining the runoff flow rate over 1 or 2 second intervals (i.e. between 3-4 seconds or 3-5 seconds) was found to be less reliable and more susceptible to flucutations caused by sensor jitter rather than meaningful changes in water level height. Calculating flow rate over a 3 second window significantly enhanced hydrograph shape as random fluctuations in water level are minimized across larger time intervals. 
        hydrograph_level_1 = hydrograph_level_2;
        hydrograph_level_2 = hydrograph_level_3;
        hydrograph_level_3 = hydrograph_level_4;
        hydrograph_level_4 = current_water_level;
        runoff_rate = (hydrograph_level_4 - hydrograph_level_1)*2.0*19.0/(hydrograph_time_4 - hydrograph_time_1); // runoff flow rate is calculated based on 3 second interval every second --> difference in water level depth divided by time elapsed (usually 3 seconds) and then multiplied by surface area of compartments in cm2
        hydrograph_time_step = (hydrograph_time_1 + hydrograph_time_4)/2.0; // the time step the calculated runoff rate occurs at is estimated at the average of the two time steps used to calculate the runoff rate
        hydrograph_time_step_length = hydrograph_time_4 - hydrograph_time_1; // similarly, the length between hydrograph time steps is calculated by subtracting the time step of the later and earlier readings used to find the runoff rate (typically 3 seconds)
        if (runoff_rate < 0){ // if for whatever reason, a negative runoff rate is returned usually as the result of sensor jitter making a later water level reading appear lower than a previous one, the runoff rate is adjusted to 0
          runoff_rate = 0.0;
        }
        filtered_runoff_rate = getMovingAverage(runoff_rate); // moving average function called to determine filtered runoff flow rate 
        //the moving average filter is configured so that the filtered runoff rate at a given time stamp requires the previous 2 and future 2 runoff flow rate readings to be averaged together. Because of this, the filtered runoff flow rate returned at a given hydrograph time step actually corresponds to the time two steps prior. For this reason, the previous two time steps must be stored.
        filtered_time_step_1 = filtered_time_step_2;
        filtered_time_step_2 = filtered_time_step_3;
        filtered_time_step_3 = hydrograph_time_step; 

        x = 32.0 + (filtered_time_step_1/(sim_duration_secs*3.0))*(290.0-32.0); // interpolation used to scale time stamp to hydrograph x axis 
        y = 145.0 - (filtered_runoff_rate/90.0)*(145.0-5.0); // interpolation used to scale runoff flow rate to hydrograph y axis 
        if (int(x) != int(last_x)){ // because the total simulation duration typically exceeds the number of pixels in the TFT display, the float values calculated for x and y are rounded to integer pixel values; this conditional statement only plots a new coordinate of the hydrograph once the x value rounds to a new integer to avoid points plotting on top of each other
          tft.drawPixel(x, y, ILI9341_WHITE); // hydrograph coordinate drawn 
          tft.drawLine(last_x, last_y, x, y, ILI9341_WHITE); // line drawn from previous hydrograph coordinate to current coordinate 
          last_x = x; // current x and y coordinates re-assigned to become previous x and y coordinates for next round of hydrograph plotting 
          last_y = y; 
        }
        tft.fillRect(240, 203, 60, 12, ILI9341_BLACK);
        tft.setCursor(240, 203);
        tft.println(filtered_runoff_rate); // filtered runoff flow rate printed to TFT display 
        Serial.print("Hydrograph Time Step: ");
        Serial.print(filtered_time_step_1); // corresponding hydrograph time step, runoff flow rate, and hydrograph time step length printed to serial monitor for validation purposes
        Serial.print("s | ");
        Serial.print("Filtered Runoff Rate: "); 
        Serial.print(filtered_runoff_rate);
        Serial.print("cm3/s | ");      
        runoff_volume_calc_2 = runoff_volume_calc_2 + filtered_runoff_rate*sensor_time_interval/1000.0; // second method of calculating runoff volume --> runoff flow rates are calculated on a second by second basis --> this calculation multiplies the filtered runoff flow rate in cm3/s by the 1 second interval between water level readings to determine the volume of water collected in that period --> this volume is then added to a running sum of runoff volume
        if (dataFile){ // opening SD card csv file 
          dataFile.print(current_time_stamp); // every second, the current time stamp, water level reading, hydrograph time step, and filtered runoff flow rate is recorded in the csv file 
          dataFile.print(",");
          dataFile.print(current_water_level);
          dataFile.print(",");
          dataFile.print(filtered_time_step_1);
          dataFile.print(",");
          dataFile.println(filtered_runoff_rate);
          dataFile.flush();
        } else { // if the SD card fails to open, the program attempts to open it one more time 
          dataFile = SD.open(file_name, FILE_WRITE);
          if (dataFile){
            dataFile.print(current_time_stamp);
            dataFile.print(",");
            dataFile.print(current_water_level);
            dataFile.print(",");
            dataFile.print(filtered_time_step_1);
            dataFile.print(",");
            dataFile.println(filtered_runoff_rate);
            dataFile.flush();
            Serial.println("Data Logged");
          }
        }
      }
      col_time_pot = analogRead(col_time_pin); // the program reads the collection time potentiometer voltage to check whether the user has adjusted the collection time interval
      collection_time_secs = 5*map(col_time_pot, 0, 1023, 1, 9); // the voltage reading is scaled to the corresponding collection time interval (0 - 45 seconds in 5 second intervals)
      collection_time_millis = collection_time_secs*1000L; // converting collection time in seconds to milliseconds 
      if (current_time - last_compartment_time >= collection_time_millis){ // conditional statement checks whether the collection time interval has passed between the last time the motor signal was called and the current time stamp
        if (current_water_level > 1 && !sent_water_signal){ // initial water level detection --> once more than 1 cm of water is detected in the first compartment, the sent_water_signal is set to true so that the motor signal can be sent
          sent_water_signal = true;
        }
        if (sent_water_signal == true && current_water_level > 0){ // conditional statement ensures collection tank is on the track and water has been detected in the compartments
          total_water_height = current_water_level + total_water_height; // before tank moves to next compartment, the final water level reading in the current compartment is added to a running sum of the total water level that has accumulated throughout the simulation
          total_runoff = total_water_height*2.0*19.0; // the cumulative runoff volume in cm3 is then calculated by multiplying the cumulative water depth by the surface area of the compartments in cm2
          last_compartment_time = current_time; // the current time is set to the previous compartment time so that this becomes the new reference point from which the collection time interval is measured from 
          runoff_volume_calc_2 = runoff_volume_calc_2 + filtered_runoff_rate*2*sensor_time_interval/1000; 
          digitalWrite(motor_active, HIGH); // the motor will now be activated so the motor active LED light is turned on while the motor inactive LED light is turned off 
          digitalWrite(motor_inactive, LOW);
          tft.fillRect(240, 191, 80, 12, ILI9341_BLACK);
          tft.setCursor(240, 191);
          tft.println(total_runoff); // cumulative runoff volume printed to TFT display
          turnMotorOn();
          delay(2750);
          digitalWrite(RELAY_PIN, LOW);
          // because the tank is moving from one compartment to the next, the stored water level variables must be adjusted to align with the 0 reference water level of new compartment (ex. if the previous three stored water levels were 10, 11, and 12 cm, it would not be accurate to use these when calculating runoff flow rate between the old and new compartment which might have initial readings of 1 or 2 cm)
          hydrograph_level_2 = 0;
          hydrograph_level_3 = 0; 
          hydrograph_level_4 = 0; 
          hydrograph_time_2 = current_time_stamp;
          hydrograph_time_3 = current_time_stamp + 1.00; 
          hydrograph_time_4 = current_time_stamp + 2.00; 
          tank_empty_count = tank_empty_count + 1; // the tank empty counter is used to keep track of which compartment the sensor is aligned under with the count restarting once the 17th compartment has been reached
          if (tank_empty_count == 17){ // checks for when the 17th compartment is aligned under the sensor 
            tank_empty_count = 0; // compartment count set back to 0 for next round of tank motion after tank has been emptied 
            digitalWrite(tank_empty, HIGH); // tank empty LED light turned on to alert user they will need to empty tank after collection interval
          } else {
            digitalWrite(tank_empty, LOW); // if the tank has not reached the last compartment, the tank empty LED light is set to off
          }
        } else { // if water has not yet been detected in the compartments or the collection tank is not on the track, the motor will not move 
          digitalWrite(motor_inactive, HIGH); // motor is not active so motor inactive LED light is turned on and motor active LED light is turned off 
          digitalWrite(motor_active, LOW);
        }
      }
      previous_time_stamp = current_time_stamp; // the current time stamp is assigned as the previous time stamp so that conditional statement at start of loop will check if 1 second has passed between this time step before taking any readings
      previous_time = current_time; 
      
    }
  }
}
